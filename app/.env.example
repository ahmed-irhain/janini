# Must be your dev machine's LAN IP, not "localhost" — Expo Go on a physical
# iPhone can't resolve "localhost" back to this machine.
EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

# RevenueCat iOS public SDK key (dashboard -> Project Settings -> API keys).
# Safe to expose client-side, same trust model as a Stripe publishable key.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxx
